<%# Anchor point for hero CTA %>
<div id="pix" class="sr-only"></div>

<%# ── MOBILE: sticky bottom bar (hidden on md+) ── %>
<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-white border-t border-warm/40 shadow-[0_-4px_16px_rgba(0,0,0,0.08)] px-4 py-3">
  <div class="flex items-center gap-2 max-w-sm mx-auto">
    <span class="text-xs font-bold text-ink shrink-0">PIX:</span>
    <code
      id="pix-key"
      data-pix-key="<%= site.data.general.pix_key %>"
      class="flex-1 font-mono text-xs font-bold text-ink bg-warm-light rounded-lg px-3 py-2 truncate"
    ><%= site.data.general.pix_key %></code>
    <button
      onclick="copyPix()"
      id="copy-btn"
      class="shrink-0 bg-primary text-white text-xs font-bold px-3 py-2 rounded-lg flex items-center gap-1 active:scale-95 transition-transform"
    >
      <i data-lucide="copy" class="w-3 h-3"></i>
      Copiar
    </button>
  </div>
</div>

<%# ── DESKTOP: fixed right sidebar (hidden below md) ── %>
<div class="hidden md:flex fixed right-4 top-1/2 -translate-y-1/2 z-50 flex-col items-center gap-3 bg-white rounded-2xl shadow-xl border border-warm/30 p-4 w-52">
  <span class="text-xs font-bold uppercase tracking-widest text-warm text-center">Doe agora via PIX</span>

  <%# QR Code placeholder — substituir div por <img src="qr.png"> com o QR real %>
  <div class="w-36 h-36 rounded-xl border-2 border-warm bg-warm-light flex items-center justify-center">
    <div class="text-center">
      <i data-lucide="qr-code" class="w-12 h-12 mb-1 mx-auto text-warm"></i>
      <p class="text-xs text-ink-light leading-tight">QR Code<br/>PIX</p>
    </div>
  </div>

  <p class="text-xs text-ink-light">ou copie a chave:</p>

  <code
    data-pix-key="<%= site.data.general.pix_key %>"
    class="w-full font-mono text-xs font-bold text-ink bg-warm-light rounded-lg px-2 py-2 text-center block break-all"
  ><%= site.data.general.pix_key %></code>

  <button
    onclick="copyPix()"
    id="copy-btn-desktop"
    class="w-full bg-primary text-white text-xs font-bold px-3 py-2 rounded-xl hover:bg-primary-dark transition-colors flex items-center justify-center gap-1"
  >
    <i data-lucide="copy" class="w-3 h-3"></i>
    Copiar chave
  </button>

  <p class="text-xs text-ink-light text-center leading-snug">qualquer valor<br/>faz diferença 🐾</p>
</div>
