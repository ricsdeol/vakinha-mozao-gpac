<%
  # size: "sm" (sidebar float) | "lg" (seção inline)
  # btn_id: ID único do botão para o JS de feedback
  size   ||= "sm"
  btn_id ||= "copy-btn"

  if size == "lg"
    key_class = "block w-full font-mono text-sm font-bold text-ink bg-warm-light rounded-xl px-4 py-3 break-all"
    btn_class = "w-full bg-primary text-white font-bold text-base px-6 py-4 rounded-2xl hover:bg-primary-dark transition-colors flex items-center justify-center gap-2 active:scale-[0.98]"
    icon_size = "w-5 h-5"
    btn_label = "Copiar chave PIX"
    label_class = "text-sm"
  else
    key_class = "w-full font-mono text-xs font-bold text-ink bg-warm-light rounded-lg px-2 py-2 text-center block break-all"
    btn_class = "w-full bg-primary text-white text-xs font-bold px-3 py-2 rounded-xl hover:bg-primary-dark transition-colors flex items-center justify-center gap-1"
    icon_size = "w-3 h-3"
    btn_label = "Copiar chave"
    label_class = "text-xs"
  end
%>
<% if size == "lg" %>
<div class="w-full">
  <p class="<%= label_class %> text-ink-light mb-2">ou copie a chave:</p>
  <code
    data-pix-key="<%= site.data.general.pix_key %>"
    class="<%= key_class %>"
  ><%= site.data.general.pix_key %></code>
</div>
<% else %>
<p class="<%= label_class %> text-ink-light">ou copie a chave:</p>
<code
  data-pix-key="<%= site.data.general.pix_key %>"
  class="<%= key_class %>"
><%= site.data.general.pix_key %></code>
<% end %>

<button
  onclick="copyPix()"
  id="<%= btn_id %>"
  class="<%= btn_class %>"
>
  <i data-lucide="copy" class="<%= icon_size %>"></i>
  <%= btn_label %>
</button>
