<%
  # size: "sm" (sidebar float) | "lg" (seção inline)
  size ||= "sm"
  wrapper = size == "lg" ? "w-48 h-48 rounded-2xl" : "w-36 h-36 rounded-xl"
%>
<img
  src="<%= relative_url '/images/pix_qr_code.jpg' %>"
  alt="QR Code PIX para doação ao GPAC"
  class="<%= wrapper %> border-2 border-warm bg-warm-light object-contain p-1"
/>
