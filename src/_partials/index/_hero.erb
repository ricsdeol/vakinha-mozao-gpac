<section class="py-20 md:py-28 px-6 bg-surface relative overflow-hidden">
  <%# Decorative blobs %>
  <div class="absolute top-0 right-0 w-72 h-72 rounded-full opacity-20 -translate-y-1/2 translate-x-1/3 bg-primary"></div>
  <div class="absolute bottom-0 left-0 w-56 h-56 rounded-full opacity-15 translate-y-1/3 -translate-x-1/4 bg-warm"></div>

  <div class="relative z-10 max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">

    <%# Left column: text content %>
    <div class="text-center md:text-left">
      <span class="inline-flex items-center gap-2 text-sm font-semibold tracking-widest uppercase mb-4 px-4 py-1 rounded-full bg-warm-light text-warm">
        <i data-lucide="cake" class="w-4 h-4"></i> Aniversário da Mariane · Em vez de presentes, doe amor
      </span>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-black mb-6 text-ink">
        Meu presente favorito<br/>
        <span class="text-primary">é uma vida salva</span>
      </h1>

      <p class="text-lg md:text-xl mb-10 max-w-lg mx-auto md:mx-0 text-ink-light">
        Neste aniversário, eu escolhi pedir algo diferente: em vez de presentes, quero que sua doação chegue para o GPAC, ONG que resgata e cuida de animais em Limeira. Qualquer valor muda uma vida.
      </p>

      <a href="#pix-section" class="inline-flex items-center gap-2 text-white font-bold text-lg px-10 py-4 rounded-2xl shadow-lg bg-primary transition-transform hover:-translate-y-0.5 hover:shadow-xl">
        <i data-lucide="paw-print" class="w-5 h-5"></i> Quero Ajudar
      </a>

      <p class="mt-5 text-sm text-ink-light">
        100% dos recursos vão direto para os animais.
      </p>
    </div>

    <%# Right column: Mariane's photo %>
    <div class="flex justify-center md:justify-end">
      <div class="rotate-2 p-3 bg-white rounded-2xl shadow-xl ring-4 ring-warm max-w-xs md:max-w-sm w-full">
        <img
          src="<%= relative_url '/images/mari_hero.jpeg' %>"
          alt="Mariane sorrindo, sentada num pelúcia de leopardo, segurando um balão vermelho e usando a camiseta do GPAC"
          class="rounded-xl w-full object-cover object-top aspect-[3/4]"
        />
        <p class="text-center text-xs font-semibold text-ink-light mt-2 pb-1 tracking-wide">
          Mariane · na sua atuação incrível no shopping em campanha do GPAC 🐾
        </p>
      </div>
    </div>

  </div>
</section>
